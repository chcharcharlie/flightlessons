rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isCFI() {
      return isSignedIn() && getUserData().role == 'CFI';
    }
    
    function isStudent() {
      return isSignedIn() && getUserData().role == 'STUDENT';
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId);
      // Simplify create rule - just check if user is creating their own document
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) && 
        // Allow updating role and cfiWorkspaceId fields during enrollment
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'cfiWorkspaceId']);
      allow delete: if false;
    }
    
    // CFI Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isSignedIn() && (
        resource.data.cfiUid == request.auth.uid ||
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/students/$(request.auth.uid))
      );
      // Allow creation if user is authenticated and creating their own workspace
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.cfiUid;
      // Allow update by CFI or when incrementing student count during enrollment
      allow update: if isSignedIn() && (
        resource.data.cfiUid == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount']))
      );
      allow delete: if false;
      
      // Study Areas subcollection
      match /studyAreas/{areaId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
        allow update: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
        allow delete: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
      }
      
      // Study Items subcollection
      match /studyItems/{itemId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
        allow update: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
        allow delete: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
      }
      
      // Lesson Templates subcollection
      match /lessonTemplates/{templateId} {
        allow read: if isSignedIn();
        allow write: if isCFI() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
      }
      
      // Students subcollection
      match /students/{studentId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid ||
          request.auth.uid == studentId
        );
        // Allow students to enroll themselves
        allow create: if isSignedIn() && 
          request.auth.uid == studentId;
        // Allow CFI to update/delete
        allow update, delete: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
      }
    }
    
    // Progress collection (separate for better querying)
    match /progress/{progressId} {
      allow read: if isSignedIn() && (
        resource.data.studentUid == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        (isCFI() && exists(/databases/$(database)/documents/workspaces/$(resource.data.cfiWorkspaceId)/students/$(resource.data.studentUid)))
      );
      allow create: if isCFI();
      allow update: if isCFI() && resource.data.createdBy == request.auth.uid;
      allow delete: if false;
    }
    
    // Lessons collection
    match /lessons/{lessonId} {
      allow read: if isSignedIn() && (
        resource.data.studentUid == request.auth.uid ||
        (isCFI() && exists(/databases/$(database)/documents/workspaces/$(resource.data.cfiWorkspaceId)))
      );
      allow write: if isCFI() && 
        exists(/databases/$(database)/documents/workspaces/$(request.resource.data.cfiWorkspaceId));
    }
    
    // ACS Elements (read-only, populated by admin)
    match /acsElements/{elementId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    
    // Invitations collection
    match /invitations/{invitationId} {
      // Allow anyone to read their own invitation (by ID)
      allow read: if true;
      // Allow updating invitation status when accepting
      allow update: if isSignedIn() && 
        request.auth.email == resource.data.email &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'accepted';
      allow create, delete: if false;
    }
  }
}