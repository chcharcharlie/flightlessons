rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isCFI() {
      return isSignedIn() && getUserData().role == 'CFI';
    }
    
    function isStudent() {
      return isSignedIn() && getUserData().role == 'STUDENT';
    }
    
    // Users collection
    match /users/{userId} {
      // Allow reading own document, CFI reading their students, or students reading their CFI
      allow read: if isOwner(userId) || 
        (isSignedIn() && getUserData().role == 'STUDENT' && 
         exists(/databases/$(database)/documents/workspaces/$(getUserData().cfiWorkspaceId)/students/$(request.auth.uid))) ||
        (isSignedIn() && isCFI() && 
         exists(/databases/$(database)/documents/workspaces/$(getUserData().cfiWorkspaceId)/students/$(userId)));
      // Simplify create rule - just check if user is creating their own document
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) && 
        // Allow updating role and cfiWorkspaceId fields during enrollment
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'cfiWorkspaceId']);
      allow delete: if false;
    }
    
    // CFI Workspaces
    match /workspaces/{workspaceId} {
      allow read: if isSignedIn() && (
        resource.data.cfiUid == request.auth.uid ||
        exists(/databases/$(database)/documents/workspaces/$(workspaceId)/students/$(request.auth.uid)) ||
        (getUserData().cfiWorkspaceId == workspaceId)
      );
      // Allow creation if user is authenticated and creating their own workspace
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.cfiUid;
      // Allow update by CFI or when incrementing student count during enrollment
      allow update: if isSignedIn() && (
        resource.data.cfiUid == request.auth.uid ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['studentCount']))
      );
      allow delete: if false;
      
      // Study Areas subcollection
      match /studyAreas/{areaId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
        allow update: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
        allow delete: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
      }
      
      // Study Items subcollection
      match /studyItems/{itemId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
        allow update: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
        allow delete: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
      }
      
      // Lesson Templates subcollection
      match /lessonTemplates/{templateId} {
        allow read: if isSignedIn();
        allow write: if isCFI() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
      }
      
      // Students subcollection
      match /students/{studentId} {
        allow read: if isSignedIn() && (
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid ||
          request.auth.uid == studentId
        );
        // Allow students to enroll themselves
        allow create: if isSignedIn() && 
          request.auth.uid == studentId;
        // Allow CFI to update/delete
        allow update, delete: if isSignedIn() && 
          get(/databases/$(database)/documents/workspaces/$(workspaceId)).data.cfiUid == request.auth.uid;
      }
    }
    
    // Progress collection (separate for better querying)
    match /progress/{progressId} {
      allow read: if isSignedIn() && (
        resource.data.studentUid == request.auth.uid ||
        resource.data.createdBy == request.auth.uid ||
        (isCFI() && exists(/databases/$(database)/documents/workspaces/$(resource.data.cfiWorkspaceId)/students/$(resource.data.studentUid)))
      );
      allow create: if isCFI();
      allow update: if isCFI() && resource.data.createdBy == request.auth.uid;
      allow delete: if false;
    }
    
    // Lessons collection
    match /lessons/{lessonId} {
      allow read: if isSignedIn() && (
        resource.data.studentUid == request.auth.uid ||
        (isCFI() && resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId)
      );
      allow create: if isCFI() && 
        request.resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId;
      allow update: if isCFI() && 
        resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId;
      allow delete: if false;
    }
    
    // ACS Elements (read-only, populated by admin)
    match /acsElements/{elementId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    
    // Invitations collection
    match /invitations/{invitationId} {
      // Allow anyone to read their own invitation (by ID)
      allow read: if true;
      // Allow updating invitation status when accepting
      allow update: if isSignedIn() && 
        request.auth.email == resource.data.email &&
        resource.data.status == 'pending' &&
        request.resource.data.status == 'accepted';
      allow create, delete: if false;
    }
    
    // Training Programs collection
    match /trainingPrograms/{programId} {
      // Allow students to read their own programs, CFIs to read programs in their workspace
      allow read: if isSignedIn() && (
        resource.data.studentUid == request.auth.uid ||
        (isCFI() && resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId)
      );
      // Allow CFIs to create programs in their workspace
      allow create: if isCFI() && 
        request.resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId &&
        request.resource.data.createdBy == request.auth.uid;
      // Allow CFIs to update/delete programs in their workspace
      allow update, delete: if isCFI() && 
        resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId;
    }
    
    // Lesson Plans collection (certificate-based, not program-specific)
    match /lessonPlans/{planId} {
      // Allow reading if user is CFI in the workspace or student enrolled in a program for this certificate
      allow read: if isSignedIn() && (
        (isCFI() && resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId) ||
        (getUserData().role == 'STUDENT' && 
         getUserData().cfiWorkspaceId == resource.data.cfiWorkspaceId)
      );
      // Allow CFIs to create/update/delete plans in their workspace
      allow create: if isCFI() && 
        request.resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId;
      allow update, delete: if isCFI() && 
        resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId;
    }
    
    // AI Progress tracking collection (temporary documents for real-time updates)
    match /aiProgress/{sessionId} {
      // Simple rules since session IDs are unique and random
      // Only authenticated users can read/write their own progress sessions
      allow read, write: if isSignedIn();
    }

    // Student questions to CFI
    match /questions/{questionId} {
      // Student can create their own questions (cfiWorkspaceId validated client-side from user doc)
      allow create: if isStudent() &&
        request.resource.data.studentUid == request.auth.uid;
      // Read: student reads own questions (query: where studentUid==uid — statically verifiable)
      //       CFI reads any question — client-side where('cfiWorkspaceId','==',wsId) handles filtering.
      //       Removing getUserData() cross-doc read so Firestore can validate queries statically.
      allow read: if isSignedIn() && (
        resource.data.studentUid == request.auth.uid ||
        isCFI()
      );
      // Update: student edits own question; CFI adds answer (any CFI — workspace filtering is client-side)
      allow update: if isSignedIn() && (
        resource.data.studentUid == request.auth.uid ||
        isCFI()
      );
      allow delete: if isSignedIn() && resource.data.studentUid == request.auth.uid;
    }

    // Student private notes (per study item)
    match /studentNotes/{noteId} {
      allow read, write: if isSignedIn() &&
        (resource == null || resource.data.studentUid == request.auth.uid) &&
        (request.resource == null || request.resource.data.studentUid == request.auth.uid);
    }

    // CFI knowledge notes pushed to students
    match /cfiNotes/{noteId} {
      // CFI can create/update/delete notes in their workspace
      allow create: if isCFI() &&
        request.resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId;
      allow update, delete: if isCFI() &&
        resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId;
      // Students can read notes targeted at them or 'all'.
      // Rules use only request.auth.uid (no getUserData cross-doc read) so that Firestore
      // can statically validate the two separate queries we run:
      //   query 1: where('cfiWorkspaceId','==',wsId).where('targetStudentUid','==','all')
      //   query 2: where('cfiWorkspaceId','==',wsId).where('targetStudentUid','==',uid)
      // In both cases resource.data.targetStudentUid is constrained by the WHERE clause,
      // so Firestore can confirm all returned docs satisfy the rules without a get() call.
      allow read: if isSignedIn() && (
        (isCFI() && resource.data.cfiWorkspaceId == getUserData().cfiWorkspaceId) ||
        (isStudent() && (resource.data.targetStudentUid == 'all' || resource.data.targetStudentUid == request.auth.uid))
      );
    }
  }
}